SENTINELOPS_CONFIG_FILE=config/sentinelops.toml
SENTINELOPS_DEPLOYMENT_MODE=local
SENTINELOPS_PUBLIC_BASE_URL=
SENTINELOPS_LOG_LEVEL=INFO
SENTINELOPS_STARTUP_VALIDATE_CONFIG=true
SENTINELOPS_TELEMETRY_ENABLED=false
SENTINELOPS_TELEMETRY_SERVICE_NAME=sentinelops-api
SENTINELOPS_TELEMETRY_EXPORTER=none
SENTINELOPS_TELEMETRY_OTLP_ENDPOINT=
SENTINELOPS_ANALYZE_MODEL=mistral
SENTINELOPS_INVESTIGATE_MODEL=mistral
SENTINELOPS_EMBEDDING_MODEL=nomic-embed-text
SENTINELOPS_MODEL_LICENSE_POLICY=permissive_only
SENTINELOPS_COMMERCIALLY_REVIEWED_MODEL_PREFIXES=mistral,ministral,nomic-embed-text
SENTINELOPS_OLLAMA_HOST=http://localhost:11434
SENTINELOPS_OLLAMA_MAX_RETRIES=2
SENTINELOPS_OLLAMA_RETRY_BACKOFF_SECONDS=0.35
SENTINELOPS_OLLAMA_CACHE_ENABLED=true
SENTINELOPS_OLLAMA_CACHE_TTL_SECONDS=900
SENTINELOPS_OLLAMA_CACHE_MAX_ENTRIES=256
SENTINELOPS_ANALYZE_MODEL_COST_PER_1K_TOKENS=0.0
SENTINELOPS_INVESTIGATE_MODEL_COST_PER_1K_TOKENS=0.0
SENTINELOPS_EMBEDDING_MODEL_COST_PER_1K_TOKENS=0.0
SENTINELOPS_ALLOWED_LOG_ROOTS=["samples","data/logs"]
SENTINELOPS_TOOL_MAX_ITERATIONS=4
SENTINELOPS_AUDIT_DB_PATH=data/runtime/audit/audit.sqlite
SENTINELOPS_METADATA_DATABASE_URL=
SENTINELOPS_WORKFLOW_CHECKPOINT_DATABASE_URL=
SENTINELOPS_KNOWLEDGE_STORE_BACKEND=simple
SENTINELOPS_KNOWLEDGE_COLLECTION_NAME=sentinelops_knowledge
SENTINELOPS_KNOWLEDGE_BASE_DIR=data/knowledge
SENTINELOPS_KNOWLEDGE_INDEX_PATH=data/knowledge_index.json
SENTINELOPS_INCIDENT_LIBRARY_DIR=data/incident_library
SENTINELOPS_REFERENCE_INCIDENTS_DIR=data/reference_incidents
SENTINELOPS_CONSOLE_TIMELINE_LIMIT=12
SENTINELOPS_WORKFLOW_RECENT_THREADS_LIMIT=25
SENTINELOPS_RETRIEVAL_CACHE_ENABLED=true
SENTINELOPS_RETRIEVAL_CACHE_TTL_SECONDS=900
SENTINELOPS_RETRIEVAL_CACHE_MAX_ENTRIES=256
SENTINELOPS_AUTH_MODE=disabled
SENTINELOPS_AUTH_API_KEY_HEADER_NAME=X-API-Key
SENTINELOPS_AUTH_API_KEY=
SENTINELOPS_AUTH_BEARER_TOKENS={}
SENTINELOPS_AUTH_OIDC_ISSUER_URL=
SENTINELOPS_AUTH_OIDC_JWKS_URL=
SENTINELOPS_AUTH_OIDC_AUDIENCE=
SENTINELOPS_AUTH_ROLE_CLAIM_PATH=realm_access.roles
SENTINELOPS_AUTH_ANALYST_ROLES=["analyst","approver","admin"]
SENTINELOPS_AUTH_APPROVER_ROLES=["approver","admin"]
SENTINELOPS_AUTH_ADMIN_ROLES=["admin"]
SENTINELOPS_CHROMA_PATH=data/chroma
SENTINELOPS_CHROMA_CLIENT_MODE=http
SENTINELOPS_CHROMA_HOST=127.0.0.1
SENTINELOPS_CHROMA_PORT=8012
SENTINELOPS_CHROMA_AUTO_START=false
SENTINELOPS_CHROMA_START_TIMEOUT_SECONDS=90
SENTINELOPS_CHROMA_WSL_DISTRO=Ubuntu
SENTINELOPS_CHROMA_WSL_BINARY=$HOME/.local/bin/chroma
SENTINELOPS_CHROMA_WSL_DATA_DIR=$HOME/.sentinelops/chroma-data
